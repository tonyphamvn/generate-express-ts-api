{
  "name": "generate-express-ts-starter",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "pm2 start ./dist/src/index.js",
    "dev": "npm run db:migrate && cross-env DEBUG=http,mail,express:* nodemon ./src/index.ts",
    "build": "tsc && tsc-alias",
    "lint": "eslint --quiet --ext=ts src",
    "lint:fix": "eslint --fix --quiet --ext=ts src",
    "db:migrate": "mikro-orm migration:up",
    "db:migrate:qa": "cross-env NODE_ENV=qa mikro-orm migration:up",
    "db:migrate:production": "cross-env NODE_ENV=production mikro-orm migration:up",
    "migration:generate": "mikro-orm migration:create --name",
    "clean": "rm -rf dist"
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./mikro-orm.config.ts"
    ]
  },
  "dependencies": {
    "@mikro-orm/core": "^6.4.13",
    "@mikro-orm/migrations": "^6.4.13",
    "@mikro-orm/postgresql": "^6.4.13",
    "@socket.io/redis-adapter": "^8.3.0",
    "@socket.io/redis-emitter": "^5.1.0",
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.3",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-validation": "^4.1.1",
    "express-winston": "^4.2.0",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.0",
    "http-status": "^2.1.0",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pm2": "^7.0.3",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^6.4.13",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-prettier": "^5.2.6",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "ajv": "^8.18.0",
    "figlet": "1.7.0"
  }
}